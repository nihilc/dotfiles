# Ghostty's website https://ghostty.org/docs/config.

#: General
# font-family = "Liberation Mono"
font-size = 13
class = ghostty

#: Behaviour
mouse-hide-while-typing = true
window-inherit-working-directory = false
gtk-tabs-location = hidden

#: Keybindings
# general
keybind = clear
keybind = ctrl+shift+comma=reload_config
# clipboard
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
# scrolling
keybind = ctrl+shift+k=scroll_page_lines:-1
keybind = ctrl+shift+j=scroll_page_lines:1
keybind = ctrl+shift+h=jump_to_prompt:-1
keybind = ctrl+shift+l=jump_to_prompt:1
# font
keybind = ctrl+shift+minus=decrease_font_size:1
keybind = ctrl+shift+equal=increase_font_size:1
keybind = ctrl+shift+0=reset_font_size
# tabs
# keybind = ctrl+shift+t=new_tab
# keybind = ctrl+shift+w=close_tab
# keybind = ctrl+shift+q=close_window
# keybind = ctrl+tab=next_tab
# keybind = ctrl+shift+tab=previous_tab

theme = noctalia
