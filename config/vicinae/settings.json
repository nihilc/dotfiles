// This configuration is merged with the default vicinae configuration file, which you can obtain by running the `vicinae config default` command.
// Every item defined in this file takes precedence over the values defined in the default config or any other imported file.
//
// You can make manual edits to this file, however you should keep in mind that this file may be written to by vicinae when a configuration change is made through the GUI.
// When that happens, any custom comments or formatting will be lost.
//
// If you want to maintain a configuration file with your own comments and formatting, you should create a separate file and add it to the 'imports' array.
//
// Learn more about configuration at https://docs.vicinae.com/config

{
   "$schema": "https://vicinae.com/schemas/config.json",
   "font": {
      "normal": {
         "family": "Inter"
      }
   },
   "theme": {
      "dark": {
         "name": "kanagawa",
         "icon_theme": "Papirus-Dark"
      }
   },
   "launcher_window": {
      "opacity": 1,
      "client_side_decorations": {
         "enabled": false
      }
   },
   "favorites": [
      "applications:app.zen_browser.zen",
      "applications:youtube-music",
      "applications:steam",
      "applications:dev.vencord.Vesktop",
      "files:search",
      "clipboard:history",
      "calculator:history",
      "font:browse"
   ],
   "providers": {
      "applications": {
         "preferences": {
            "defaultAction": "focus",
            "paths": [
               "/home/nihilc/.local/share/applications",
               "/var/lib/flatpak/exports/share/applications",
               "/usr/share/applications"
            ]
         },
         "entrypoints": {
            "avahi-discover": {
               "enabled": false
            },
            "bssh": {
               "enabled": false
            },
            "bvnc": {
               "enabled": false
            },
            "cmake-gui": {
               "enabled": false
            },
            "htop": {
               "enabled": false
            },
            "mpv": {
               "enabled": false
            },
            "org.freedesktop.IBus.Setup": {
               "enabled": false
            },
            "org.freedesktop.MalcontentControl": {
               "enabled": false
            },
            "org.gnome.ColorProfileViewer": {
               "enabled": false
            },
            "qv4l2": {
               "enabled": false
            },
            "qvidcap": {
               "enabled": false
            },
            "rygel-preferences": {
               "enabled": false
            },
            "vicinae": {
               "enabled": false
            }
         }
      },
      "browser-extension": {
         "enabled": false
      },
      "clipboard": {
         "entrypoints": {
            "clear": {
               "enabled": false
            },
            "clear-history": {
               "enabled": false
            },
            "history": {
               "preferences": {
                  "defaultAction": "copy"
               }
            }
         }
      },
      "core": {
         "enabled": false
      },
      "developer": {
         "enabled": false
      },
      "manage-shortcuts": {
         "enabled": true
      },
      "power": {
         "enabled": false,
         "entrypoints": {
            "hibernate": {
               "enabled": true
            },
            "sleep": {
               "enabled": false
            },
            "soft-reboot": {
               "enabled": false
            }
         }
      },
      "raycast-compat": {
         "enabled": false
      },
      "system": {
         "enabled": false
      },
      "theme": {
         "enabled": false
      },
      "wm": {
         "enabled": false
      }
   }
}